# ============================================================================
# Pralkowcy Scraper - Environment Variables Template
# ============================================================================
# Skopiuj ten plik jako .env i wpisz swoje wartości
# cp .env.example .env
# ============================================================================

# ============================================================================
# SUPABASE - PostgreSQL Database
# ============================================================================
# Pobierz z: https://app.supabase.com/project/YOUR_PROJECT/settings/api

SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# GOOGLE DRIVE & SHEETS
# ============================================================================
# Credentials file location - plik powinien być w config/

GOOGLE_CREDENTIALS_FILE=config/pralkowcy-scraper-04aaed542e48.json

# Google Drive folder ID (z URL: https://drive.google.com/drive/folders/XXXX)
GOOGLE_DRIVE_FOLDER_ID=YOUR_FOLDER_ID_HERE

# Google Sheets ID (z URL: https://docs.google.com/spreadsheets/d/XXXX/edit)
GOOGLE_SHEET_ID=YOUR_SHEET_ID_HERE

# ============================================================================
# SCRAPOWANIE - Konfiguracja
# ============================================================================

# URL do scrapowania
SCRAPE_URL=https://elektorda.pl

# Opóźnienie między requestami (sekundy)
SCRAPE_DELAY_MIN=7
SCRAPE_DELAY_MAX=10

# Max requestów na dzień
SCRAPE_MAX_REQUESTS_PER_DAY=50

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Czy wypisywać do konsoli?
LOG_TO_CONSOLE=true

# Czy wypisywać do pliku?
LOG_TO_FILE=true

# ============================================================================
# NOTKI
# ============================================================================
# 1. NIGDY nie commituj .env do Git'a!
#    Dodaj do .gitignore: .env .env.local .env.*
#
# 2. Supabase URL i KEY są publiczne (anon key) - bezpieczne
#    Ale ochroniaj je przed wyciekiem
#
# 3. Google credentials - TAJNE!
#    Trzymaj service account key.json w config/
#
# 4. Po zmianach tutaj, restart aplikacji:
#    python main.py
#
# 5. Troubleshooting:
#    Sprawdzaj logi: tail -50 logs/*.log
# ============================================================================
